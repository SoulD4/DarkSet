rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /squads/{squadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.donoUid == request.auth.uid;
    }

    match /squads/{squadId}/{subcol}/{docId} {
      allow read, write: if request.auth != null;
    }

    match /globalRank/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Personal — leitura/escrita pelo próprio uid
    match /personals/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Requests de personal — escrita pelo próprio, leitura só admin
    match /personal_requests/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Invites — personal cria, qualquer auth lê para validar código
    match /personal_invites/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Links personal-aluno
    match /personal_links/{linkId} {
      allow read, write: if request.auth != null;
    }

    // Planos do personal para alunos
    match /personal_plans/{studentUid}/plans/{planId} {
      allow read, write: if request.auth != null;
    }
  }
}
