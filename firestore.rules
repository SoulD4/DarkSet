rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dados pessoais do usuário
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Squads — qualquer autenticado pode ler para buscar por código
    match /squads/{squadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // dono pode tudo
        resource.data.donoUid == request.auth.uid ||
        // membros podem atualizar apenas campos permitidos
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['membros','updatedAt'])
      );
      allow delete: if request.auth != null &&
        resource.data.donoUid == request.auth.uid;
    }

    // Chat do squad — apenas membros
    match /squads/{squadId}/chat/{msgId} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/squads/$(squadId)/membros/$(request.auth.uid));
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/squads/$(squadId)/membros/$(request.auth.uid));
    }

    // Membros do squad
    match /squads/{squadId}/membros/{uid} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/squads/$(squadId)/membros/$(request.auth.uid));
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Checkins do squad
    match /squads/{squadId}/checkins/{docId} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/squads/$(squadId)/membros/$(request.auth.uid));
      allow create: if request.auth != null &&
        exists(/databases/$(database)/documents/squads/$(squadId)/membros/$(request.auth.uid)) &&
        request.resource.data.uid == request.auth.uid;
    }

    // Rank mensal
    match /squads/{squadId}/rank/{mes}/scores/{uid} {
      allow read: if request.auth != null &&
        exists(/databases/$(database)/documents/squads/$(squadId)/membros/$(request.auth.uid));
      allow write: if request.auth != null && request.auth.uid == uid &&
        exists(/databases/$(database)/documents/squads/$(squadId)/membros/$(request.auth.uid));
    }
  }
}
